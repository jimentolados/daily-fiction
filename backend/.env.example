# ─── Django ───────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-generate-with-django-get-random-secret-key

# ─── Base de datos (PostgreSQL en Docker) ─────────────────
DB_NAME=dailyfiction_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# ─── APIs externas ────────────────────────────────────────
TMDB_API_KEY=
OMDB_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── CORS (producción) ────────────────────────────────────
# ALLOWED_HOSTS=dailyfiction.es,www.dailyfiction.es
# CORS_ALLOWED_ORIGINS=https://dailyfiction.es
